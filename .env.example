# Storage
STORAGE_PROVIDER=local
S3_BUCKET=vidlocal
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI
STT_PROVIDER=faster-whisper
MODEL_NAME=large-v3
WHISPER_MODEL_NAME=base
GOOGLE_PROJECT_ID=
# faster-whisper | google
AI_PROVIDER=gemini
AI_MODEL=
GEMINI_API_KEY=your-gemini-key
GEMINI_TIMEOUT_SECONDS=60.0
GEMINI_RETRIES=2
DEEPL_API_KEY=
TRANSLATE_PROVIDER=deeplx
DEEPLX_BASE_URL=http://deeplx:1188
DEEPLX_TIMEOUT_SECONDS=20.0
DEEPLX_RETRIES=2
TTS_PROVIDER=edge-tts
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
TTS_TIMEOUT_SECONDS=60.0
TTS_RETRIES=2
ELEVENLABS_API_KEY=
SUBTITLE_OUTPUT_MODE=translated
# translated | bilingual | original_plus_translated

# Platform OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://developers.google.com/oauthplayground
YOUTUBE_REFRESH_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_COOKIES_FILE=/root/vidlocal/cookies/facebook.txt
BILIBILI_COOKIES_FILE=/app/cookies/bilibili.txt
DOUYIN_COOKIES_FILE=
DOUYIN_PROXY=
DOUYIN_USER_AGENT=
DOWNLOAD_TIMEOUT_SECONDS=900

# R2 (Cloudflare R2 backup for facebook downloads, 3-day retention)
R2_ENABLED=false
R2_BUCKET=vidlocal
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_RETENTION_DAYS=3

# Telegram Bot (Facebook→YouTube automation)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Infra - MUST CHANGE these in production
DATABASE_URL=postgresql+asyncpg://vidlocal:vidlocal123@db:5432/vidlocal
REDIS_URL=redis://redis:6379/0
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Generate: openssl rand -base64 32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# App
PROJECT_DATA_DIR=/app/data/projects
MAX_UPLOAD_SIZE=2147483648

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
